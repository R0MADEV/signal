{
  "name": "signal-mcp",
  "version": "0.1.0",
  "description": "MCP server that extracts compact diagnostics from noisy developer tooling output.",
  "type": "module",
  "private": true,
  "bin": {
    "signal-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "execa": "^9.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.9"
  }
}
